# Read-only DSN against the Postgres owned by hr-backend (host-exposed by docker-compose).
DATABASE_URL=postgresql://hr:hr_secret@localhost:5432/hr_platform

# --- Document extraction (Sprint 1, ADR-0010) ---
# Shared S3-compatible object storage (MinIO in dev). Must match hr-backend's bucket.
AWS_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_BUCKET=hr-documents
AWS_USE_PATH_STYLE=true
EXTRACT_IMAGE_DPI=150

# Shared secret guarding internal endpoints (hr-backend ↔ hr-ai). Must match hr-backend's HR_AI_INTERNAL_TOKEN.
INTERNAL_TOKEN=dev-internal-token

# --- Placeholders (unused this sprint) ---
EMBED_MODEL=BGE-M3
EMBED_DIM=1024
ANTHROPIC_API_KEY=
